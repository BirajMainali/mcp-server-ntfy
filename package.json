{
  "name": "mcp-server-ntfy",
  "version": "1.1.3",
  "description": "ntfy MCP server—reach the operator on their phone and wait for a reply before continuing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-ntfy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "tsx --test src/**/*.test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ntfy",
    "notifications",
    "cursor",
    "push"
  ],
  "author": "Biraj Mainali",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BirajMainali/mcp-server-ntfy.git"
  },
  "homepage": "https://github.com/BirajMainali/mcp-server-ntfy#readme",
  "bugs": {
    "url": "https://github.com/BirajMainali/mcp-server-ntfy/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
